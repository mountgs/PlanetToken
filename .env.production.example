# Production environment template for docker-compose.prod.yml
#
# Setup:
#   cp .env.production.example .env.production
#   # Edit secrets below, then:
#   chmod 600 .env.production
#
# Generate secrets (run on the server):
#   openssl rand -hex 32

# --- PostgreSQL (internal Docker network only) ---
POSTGRES_USER=newapi
POSTGRES_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32
POSTGRES_DB=new-api

# --- Redis (internal Docker network only) ---
REDIS_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32

# --- Application secrets (required) ---
SESSION_SECRET=CHANGE_ME_use_openssl_rand_hex_32
CRYPTO_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# --- Application settings ---
TZ=Asia/Shanghai
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
NODE_NAME=new-api-prod-1

# Image tag (official registry; pin a release tag in production when possible)
NEW_API_IMAGE=calciumion/new-api:latest

# Optional: restrict redirect URLs for payment callbacks (comma-separated domains)
# TRUSTED_REDIRECT_DOMAINS=example.com

# Never enable in production:
# TLS_INSECURE_SKIP_VERIFY=false
# DEBUG=false
